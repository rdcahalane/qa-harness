  "secret_patterns": [
    "(?i)(api[_-]?key|apikey|secret[_-]?key|auth[_-]?token|access[_-]?token|private[_-]?key|password|passwd|credential)\\s*[:=]\\s*[\"'][^\"']{8,}[\"']",
    "(?i)(supabase|anthropic|openai|stripe|twilio|sendgrid|aws|firebase|heroku|vercel|cloudflare|railway|github|slack|telegram|discord).*[:=]\\s*[\"'][A-Za-z0-9_\\-\\.]{20,}[\"']",
    "sk-[A-Za-z0-9]{20,}",
    "ghp_[A-Za-z0-9]{36}",
    "eyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}",
    "xoxb-[0-9]{10,}-[A-Za-z0-9]{20,}",
    "-----BEGIN (RSA |EC )?PRIVATE KEY-----"
  ],
  "safe_secret_files": [
    ".env", ".env.local", ".env.development", ".env.production",
    ".env.example", ".env.sample", ".env.template"
  ],
  "report_dir": "/tmp",
  "openbrain_url": "http://localhost:3210",
  "openbrain_token": "openbrain-dev-token",
  "alert_file": "/tmp/qa-alert.txt"
